# Server configuration
PORT=5000

# Database Configuration (Supabase or Render PostgreSQL)
# Option A: Unified Connection String (Recommended)
DATABASE_URL=postgresql://postgres:your-supabase-password@db.supabase.co:5432/postgres

# Option B: Individual connection parameters (Fallback)
PGHOST=db.supabase.co
PGUSER=postgres
PGPASSWORD=your-supabase-password
PGDATABASE=postgres
PGPORT=5432
PGSSL=true
